# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/bloodbridge

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Twilio (Voice + SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_TWIML_APP_SID=your_twiml_app_sid

# Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI (for call dialogue / speech processing)
OPENAI_API_KEY=your_openai_api_key

# App
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Hospital (single hospital MVP)
HOSPITAL_NAME=City Hospital
HOSPITAL_ADDRESS=123 Medical Center Drive, City, State 12345
HOSPITAL_LAT=40.7128
HOSPITAL_LNG=-74.0060

# Donor search radius (km)
DEFAULT_SEARCH_RADIUS_KM=25
MAX_SEARCH_RADIUS_KM=100

# Call settings
CALL_TIMEOUT_SECONDS=30
NO_ANSWER_WAIT_SECONDS=20
